{
  "project": {
    "name": "MediaForgeTool",
    "type": "python",
    "lang": "fr",
    "icon": "*",
    "timeout": 1800
  },
  "menus": {
    "main": {
      "title": "MediaForgeTool",
      "items": [
        {
          "label": "Sync dev",
          "icon": "*",
          "key": "i",
          "argv": ["rtk", "uv", "sync", "--dev"],
          "desc": "Installe l environnement Python et les dependances de developpement"
        },
        {
          "label": "Serveur",
          "icon": ">",
          "key": "r",
          "submenu": "server"
        },
        {
          "label": "Tests",
          "icon": "T",
          "key": "t",
          "argv": ["rtk", "uv", "run", "pytest"]
        },
        {
          "label": "Lint",
          "icon": "L",
          "key": "l",
          "argv": ["rtk", "uv", "run", "ruff", "check", "."]
        },
        {
          "label": "Check complet",
          "icon": "+",
          "key": "c",
          "commands": [
            ["rtk", "uv", "run", "ruff", "check", "."],
            ["rtk", "uv", "run", "pytest"],
            ["rtk", "uv", "run", "python", "-m", "compileall", "app"]
          ],
          "desc": "Lint, tests et compilation Python"
        },
        {
          "label": "API jobs",
          "icon": "@",
          "key": "a",
          "argv": [
            "rtk",
            "uv",
            "run",
            "python",
            "-c",
            "from app.core.config import get_settings; from urllib.request import urlopen; s = get_settings(); url = f'http://{s.app_host}:{s.app_port}/api/jobs'; print(urlopen(url, timeout=5).read().decode('utf-8'))"
          ],
          "desc": "Affiche l historique local si le serveur est lance"
        },
        {
          "label": "API Atelier",
          "icon": "A",
          "key": "m",
          "argv": [
            "rtk",
            "uv",
            "run",
            "python",
            "-c",
            "from app.core.config import get_settings; from urllib.request import urlopen; s = get_settings(); url = f'http://{s.app_host}:{s.app_port}/api/studio/assets'; print(urlopen(url, timeout=5).read().decode('utf-8'))"
          ],
          "desc": "Affiche les assets Atelier si le serveur est lance"
        },
        {
          "label": "Podman",
          "icon": "P",
          "key": "d",
          "submenu": "docker"
        },
        {
          "label": "Docs",
          "icon": "?",
          "key": "o",
          "submenu": "docs"
        },
        {
          "label": "Git branches",
          "icon": "G",
          "key": "g",
          "submenu": "auto:git"
        },
        {
          "label": "Historique",
          "icon": "H",
          "key": "h",
          "action": "history"
        },
        {
          "label": "Quitter",
          "icon": "X",
          "key": "x",
          "action": "exit"
        }
      ]
    },
    "server": {
      "title": "MediaForgeTool - Serveur",
      "items": [
        {
          "label": "Start",
          "icon": ">",
          "key": "s",
          "argv": ["rtk", "uv", "run", "python", "scripts/dev_server.py", "start"],
          "desc": "Demarre MediaForgeTool en arriere-plan avec APP_HOST et APP_PORT"
        },
        {
          "label": "Stop",
          "icon": "x",
          "key": "x",
          "argv": ["rtk", "uv", "run", "python", "scripts/dev_server.py", "stop"],
          "desc": "Arrete le serveur de developpement"
        },
        {
          "label": "Restart",
          "icon": "R",
          "key": "r",
          "argv": ["rtk", "uv", "run", "python", "scripts/dev_server.py", "restart"],
          "desc": "Redemarre le serveur de developpement"
        },
        {
          "label": "Status",
          "icon": "S",
          "key": "t",
          "argv": ["rtk", "uv", "run", "python", "scripts/dev_server.py", "status"],
          "desc": "Affiche le PID, l URL et l etat healthcheck"
        },
        {
          "label": "Logs",
          "icon": "L",
          "key": "l",
          "argv": ["rtk", "uv", "run", "python", "scripts/dev_server.py", "logs"],
          "desc": "Affiche les dernieres lignes du log serveur"
        },
        {
          "label": "Retour",
          "icon": "<",
          "key": "z",
          "submenu": "main"
        }
      ]
    },
    "docker": {
      "title": "MediaForgeTool - Podman",
      "items": [
        {
          "label": "Build image",
          "icon": "B",
          "key": "b",
          "argv": [
            "C:\\Program Files\\RedHat\\Podman\\podman.exe",
            "build",
            "-t",
            "mediaforgetool:mvp",
            "."
          ]
        },
        {
          "label": "Compose up",
          "icon": ">",
          "key": "u",
          "argv": [
            "powershell",
            "-NoProfile",
            "-Command",
            "if (-not (Test-Path .env)) { Copy-Item .env.example .env }; & 'C:\\Program Files\\RedHat\\Podman\\podman.exe' compose up --build"
          ],
          "desc": "Cree .env depuis .env.example si necessaire puis lance compose"
        },
        {
          "label": "Compose down",
          "icon": "x",
          "key": "s",
          "argv": [
            "C:\\Program Files\\RedHat\\Podman\\podman.exe",
            "compose",
            "down"
          ]
        },
        {
          "label": "Compose logs",
          "icon": "L",
          "key": "l",
          "argv": [
            "C:\\Program Files\\RedHat\\Podman\\podman.exe",
            "compose",
            "logs",
            "-f",
            "mediaforgetool"
          ]
        },
        {
          "label": "Retour",
          "icon": "<",
          "key": "z",
          "submenu": "main"
        }
      ]
    },
    "docs": {
      "title": "MediaForgeTool - Docs",
      "items": [
        {
          "label": "README",
          "icon": "R",
          "key": "r",
          "argv": [
            "powershell",
            "-NoProfile",
            "-Command",
            "Get-Content -LiteralPath README.md -TotalCount 260"
          ]
        },
        {
          "label": "Architecture",
          "icon": "A",
          "key": "a",
          "argv": [
            "powershell",
            "-NoProfile",
            "-Command",
            "Get-Content -LiteralPath docs/architecture.md -TotalCount 240"
          ]
        },
        {
          "label": "Retour",
          "icon": "<",
          "key": "z",
          "submenu": "main"
        }
      ]
    }
  }
}
